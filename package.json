{
  "name": "debugpilot",
  "displayName": "DebugPilot",
  "description": "MCP server exposing VS Code Debug Adapter Protocol to AI agents",
  "version": "0.6.1",
  "publisher": "inkan-link",
  "license": "Apache-2.0",
  "icon": "assets/icon.png",
  "homepage": "https://github.com/inkan-tech/DebugPilot",
  "repository": {
    "type": "git",
    "url": "https://github.com/inkan-tech/DebugPilot"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "mcp",
    "debug",
    "ai",
    "debugger",
    "dap"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "DebugPilot",
      "properties": {
        "debugPilot.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable DebugPilot MCP server"
        },
        "debugPilot.consoleBufferSize": {
          "type": "number",
          "default": 10000,
          "description": "Maximum number of debug console messages to buffer"
        },
        "debugPilot.variableDepthLimit": {
          "type": "number",
          "default": 1,
          "description": "Default depth limit for variable expansion"
        },
        "debugPilot.sourceContextLines": {
          "type": "number",
          "default": 10,
          "description": "Number of source lines to show above and below the current line"
        }
      }
    },
    "commands": [
      {
        "command": "debugPilot.restart",
        "title": "DebugPilot: Restart MCP Server"
      },
      {
        "command": "debugPilot.showStatus",
        "title": "DebugPilot: Show Status"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:watch": "node esbuild.config.mjs --watch",
    "build:check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package --no-dependencies",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/vscode": "^1.96.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
